{
  "table_name": "pokemon_stat_canonical",
  "purpose": "canonical PokéAPI stat snapshot",
  "primary_key": "pokemon_stat_canonical_key",
  "join_keys": ["pokemon_key", "pokemon_id"],
  "fields": [
    {"name": "pokemon_stat_canonical_key", "type": "string", "required": true, "description": "Primary key for this stat snapshot row"},
    {"name": "pokemon_key", "type": "string", "required": true, "description": "Foreign key to pokemon.pokemon_key"},
    {"name": "pokemon_id", "type": "integer", "required": true, "description": "Canonical Pokédex identifier"},
    {"name": "hp", "type": "integer", "required": true, "description": "Base HP stat"},
    {"name": "attack", "type": "integer", "required": true, "description": "Base Attack stat"},
    {"name": "defense", "type": "integer", "required": true, "description": "Base Defense stat"},
    {"name": "sp_attack", "type": "integer", "required": true, "description": "Base Special Attack stat"},
    {"name": "sp_defense", "type": "integer", "required": true, "description": "Base Special Defense stat"},
    {"name": "speed", "type": "integer", "required": true, "description": "Base Speed stat"},
    {"name": "stat_total", "type": "integer", "required": true, "description": "Sum of the six base stats"},
    {"name": "source_name", "type": "string", "required": true, "description": "Constant: PokéAPI"},
    {"name": "source_url", "type": "string", "required": true, "description": "Source URL or endpoint the record was resolved from"},
    {"name": "source_record_id", "type": "string", "required": true, "description": "Upstream PokéAPI record identifier"},
    {"name": "extracted_at_utc", "type": "string", "required": true, "description": "ISO-8601 UTC extraction timestamp"},
    {"name": "dataset_version", "type": "string", "required": true, "description": "Dataset version this row was published under"}
  ]
}

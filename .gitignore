# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/

# dbt
dbt/target/
dbt/logs/
dbt/dbt_packages/
dbt/data/*.duckdb
dbt/data/*.duckdb.wal
dbt/.user.yml

# Generated validation reports (template stays tracked)
reports/validation/validation_report.json
!reports/validation/validation_report.template.json

# dbt build outputs: regenerated by `dbt build` every run, never need committing
data/normalized/*.csv
data/marts/*.csv

# Raw source snapshots: regenerable via `python -m pipelines.cli extract
# <source>` (pokeapi | opgg | munchstats). These grow/change on every
# refresh per dataset-spec.md's refresh policy (daily for OP.GG/MunchStats,
# weekly for PokéAPI) and munchstats.csv alone is already ~37MB, so they're
# not committed — unlike data/normalized/, schema contracts for these live
# in data/staging/*.schema.json (tracked) rather than in the data itself.
data/staging/*.csv

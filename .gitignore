# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/

# dbt
dbt/target/
dbt/logs/
dbt/dbt_packages/
dbt/data/*.duckdb
dbt/data/*.duckdb.wal
dbt/.user.yml

# Generated validation reports (template stays tracked)
reports/validation/validation_report.json
!reports/validation/validation_report.template.json

# dbt build outputs: regenerated by `dbt build` every run, never need committing
data/normalized/*.csv

# NOTE: data/staging/*.csv is intentionally NOT ignored yet. This pass
# commits empty, header-only placeholder CSVs so dbt sources resolve before
# real ingestion exists (unlike data/normalized/, these are inputs, not
# regenerable outputs). Once Phase 1 extraction lands, revisit whether real
# staging snapshots should move to gitignored/regenerable status.
